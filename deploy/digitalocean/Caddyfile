	email {$TLS_EMAIL}
}

{$API_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	reverse_proxy api:7860 {
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}
}

